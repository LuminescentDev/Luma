    "pg": "^8.22.0",
    "redis": "^6.1.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.1",
    "typescript": "~5.8.3",
    "vitest": "^4.1.10"
  }
}
