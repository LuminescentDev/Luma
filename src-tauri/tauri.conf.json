{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Luma",
  "version": "0.10.0",
  "identifier": "dev.bwmp.luma",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm apple:icon && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Luma",
        "width": 1200,
        "height": 780,
        "minWidth": 720,
        "minHeight": 480,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "iOS": {
      "developmentTeam": "828MX392ZN"
    },
    "macOS": {
      "entitlements": "Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/star.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "PLACEHOLDER_CI_INJECTS_TAURI_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/OWNER/luma/releases/latest/download/latest.json"
      ]
    }
  }
}
