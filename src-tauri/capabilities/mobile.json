{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "mobile",
  "description": "Mobile capability for the main webview",
  "windows": ["main"],
  "platforms": ["android", "iOS"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:default",
    "allow-mobile-commands",
    "allow-derive-public-key"
  ]
}
